# --- The 5-Agent SupportSignal System ---

class SupportSignal:
    def __init__(self, ticket_id, must_gather_url):
        self.ticket_id = ticket_id
        self.must_gather_url = must_gather_url
        self.context = {}

    def run_workflow(self):
        print(f"🚀 Starting supportSignal for Ticket: {self.ticket_id}")
        
        # 1. Log Analyst: Parse Must-Gather (using the provided URL)
        # In a real scenario, you'd download and extract here
        self.context['raw_logs'] = "ERROR: [RHOAI] NVIDIA GPU Operator: Failed to reconcile. Error: VersionMismatch"
        
        # 2. Knowledge Retrieval: Search KCS/BZ
        # Simulating hit from Vector DB
        self.context['kcs_docs'] = "KCS#7012345: GPU Operator 23.9 requires OCP 4.14+."

        # 3. Domain Specialist: RHOAI specific checks
        # Logic to check if RHOAI components are 'Ready'
        self.context['rhoai_status'] = "NotebookController: Degraded"

        # 4. Draft Synthesis: The Consultant
        draft = self.generate_draft()
        
        # 5. Guardian Agent: The Auditor
        final_validated_report = self.audit_report(draft)
        
        return final_validated_report

    def generate_draft(self):
        prompt = f"""[INST] Generate a Diagnostic Brief.
        LOGS: {self.context['raw_logs']}
        KCS: {self.context['kcs_docs']}
        STATUS: {self.context['rhoai_status']}
        [/INST]"""
        return support_llm.invoke(prompt).content

    def audit_report(self, draft):
        # Using the same endpoint, but with "Guardian" style instructions
        audit_prompt = f"""[INST] You are Granite Guardian 3.0. 
        Verify if the following report commands are safe for OCP.
        REPORT: {draft}
        [/INST]"""
        return support_llm.invoke(audit_prompt).content

